<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:VaultNote.Mobile"
             x:Class="VaultNote.Mobile.SearchNotesPage"
             Title="Search Notes">

    <Grid RowDefinitions="Auto,Auto,*,Auto" Padding="16" RowSpacing="8">

        <Label Grid.Row="0"
               Text="Search Notes"
               Style="{StaticResource Headline}"
               SemanticProperties.HeadingLevel="Level1" />

        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <Entry Grid.Column="0"
                   x:Name="QueryEntry"
                   Placeholder="Search keyword…"
                   ClearButtonVisibility="WhileEditing" />
            <Button Grid.Column="1"
                    x:Name="SearchButton"
                    Text="Search"
                    Clicked="OnSearchClicked" />
        </Grid>

        <CollectionView Grid.Row="2"
                        x:Name="ResultsCollection"
                        EmptyView="No results. Enter a keyword and tap Search.">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="local:NoteItem">
                    <Border Stroke="{StaticResource Primary}"
                            StrokeThickness="1"
                            Padding="12"
                            Margin="0,4">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding Title}"
                                   FontAttributes="Bold"
                                   FontSize="16"
                                   LineBreakMode="TailTruncation" />
                            <Label Text="{Binding Content}"
                                   FontSize="13"
                                   LineBreakMode="TailTruncation"
                                   MaxLines="2"
                                   TextColor="{StaticResource Gray600}" />
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Label Grid.Row="3"
               x:Name="StatusLabel"
               Text=""
               FontSize="13"
               LineBreakMode="WordWrap" />

    </Grid>

</ContentPage>
