<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VaultNote.Mobile.AskVaultPage"
             Title="Ask Vault">

    <Grid RowDefinitions="Auto,*,Auto,Auto" Padding="16" RowSpacing="8">

        <Label Grid.Row="0"
               Text="Ask Vault"
               Style="{StaticResource Headline}"
               SemanticProperties.HeadingLevel="Level1" />

        <ScrollView Grid.Row="1" x:Name="AnswerScroll">
            <Label x:Name="AnswerLabel"
                   Text="Ask a question about your notes."
                   FontSize="15"
                   LineBreakMode="WordWrap"
                   Padding="4" />
        </ScrollView>

        <Grid Grid.Row="2" ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <Entry Grid.Column="0"
                   x:Name="QuestionEntry"
                   Placeholder="Ask a question…"
                   ClearButtonVisibility="WhileEditing" />
            <Button Grid.Column="1"
                    x:Name="AskButton"
                    Text="Ask"
                    Clicked="OnAskClicked" />
        </Grid>

        <Label Grid.Row="3"
               x:Name="StatusLabel"
               Text=""
               FontSize="13"
               LineBreakMode="WordWrap" />

    </Grid>

</ContentPage>
